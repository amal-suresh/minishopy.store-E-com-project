{{!-- Hero Slider Section --}}
<section id="home-section" class="hero-slider">
    <div class="slider-container">
        {{#each bannerData}}
        <div class="slide {{#if @first}}active{{/if}}">
            <div class="slide-overlay"></div>
            <img src="productImages/{{image}}" alt="{{title}}">
            <div class="slide-content">
                <div class="content-box">
                    <span class="subtitle">{{subtitle}}</span>
                    <h1>{{title}}</h1>
                    <p>{{discription}}</p>
                    <a href="{{url}}" class="btn">Discover Now →</a>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    
    <button class="prev" onclick="changeSlide(-1)">‹</button>
    <button class="next" onclick="changeSlide(1)">›</button>
    
    <div class="dots">
        {{#each bannerData}}
        <span class="dot {{#if @first}}active{{/if}}" onclick="currentSlide({{@index}})"></span>
        {{/each}}
    </div>
</section>

<style>
    .hero-slider {
        position: relative;
        width: 100%;
        min-height: 100vh;
        height: 100vh;
        overflow: hidden;
        background: #0a0a0a;
        margin-top: 0;
        padding-top: 0;
    }

    .slider-container {
        width: 100%;
        height: 100%;
        position: relative;
    }

    .slide {
        display: none;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .slide.active {
        display: block;
        animation: fadeIn 1s ease-in;
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .slide img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    .slide-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            135deg,
            rgba(10, 10, 10, 0.8) 0%,
            rgba(10, 10, 10, 0.6) 50%,
            rgba(10, 10, 10, 0.4) 100%
        );
        z-index: 1;
    }

    .slide-content {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding: 0 8%;
        z-index: 2;
    }

    .content-box {
        max-width: 700px;
        color: white;
        animation: slideUp 1s ease-out;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .subtitle {
        color: #dbcc8f;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 3px;
        margin-bottom: 20px;
        display: inline-block;
        font-weight: 500;
        position: relative;
        padding-left: 50px;
    }

    .subtitle::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 40px;
        height: 1px;
        background: #dbcc8f;
    }

    .content-box h1 {
        font-size: clamp(2.5rem, 6vw, 5rem);
        margin-bottom: 25px;
        font-weight: 700;
        line-height: 1.1;
        color: #fff;
    }

    .content-box p {
        font-size: clamp(1rem, 2vw, 1.2rem);
        margin-bottom: 40px;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.85);
        max-width: 600px;
    }

    .btn {
        display: inline-block;
        padding: 18px 45px;
        background: transparent;
        border: 2px solid #dbcc8f;
        color: #dbcc8f;
        text-decoration: none;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 2px;
        font-weight: 600;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

    .btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: #dbcc8f;
        transition: left 0.4s ease;
        z-index: -1;
    }

    .btn:hover::before {
        left: 0;
    }

    .btn:hover {
        color: #000;
        border-color: #dbcc8f;
    }

    .prev, .next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(219, 204, 143, 0.5);
        color: #dbcc8f;
        font-size: 35px;
        width: 60px;
        height: 60px;
        cursor: pointer;
        z-index: 10;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(5px);
    }

    .prev:hover, .next:hover {
        background: #dbcc8f;
        color: #000;
        border-color: #dbcc8f;
    }

    .prev {
        left: 30px;
    }

    .next {
        right: 30px;
    }

    .dots {
        position: absolute;
        bottom: 50px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        display: flex;
        gap: 15px;
    }

    .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(219, 204, 143, 0.4);
        cursor: pointer;
        transition: all 0.4s ease;
        border: 2px solid transparent;
    }

    .dot:hover {
        background: rgba(219, 204, 143, 0.7);
    }

    .dot.active {
        background: #dbcc8f;
        width: 40px;
        border-radius: 8px;
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .slide-content {
            padding: 0 5%;
        }

        .prev, .next {
            width: 50px;
            height: 50px;
            font-size: 28px;
        }

        .prev {
            left: 20px;
        }

        .next {
            right: 20px;
        }
    }

    @media (max-width: 768px) {
        .hero-slider {
            min-height: calc(100vh - 60px);
            height: auto;
        }

        .slide-content {
            padding: 80px 20px 100px;
            justify-content: center;
            text-align: center;
        }

        .content-box {
            max-width: 100%;
        }

        .content-box h1 {
            font-size: 2.2rem;
        }

        .content-box p {
            font-size: 1rem;
            margin-bottom: 30px;
        }

        .btn {
            padding: 15px 35px;
            font-size: 12px;
        }

        .subtitle {
            padding-left: 0;
            margin-bottom: 15px;
        }

        .subtitle::before {
            display: none;
        }

        .prev, .next {
            width: 45px;
            height: 45px;
            font-size: 24px;
        }

        .prev {
            left: 15px;
        }

        .next {
            right: 15px;
        }

        .dots {
            bottom: 30px;
        }

        .slide-overlay {
            background: rgba(10, 10, 10, 0.7);
        }
    }

    @media (max-width: 480px) {
        .content-box h1 {
            font-size: 1.8rem;
            margin-bottom: 15px;
        }

        .content-box p {
            font-size: 0.95rem;
        }

        .prev, .next {
            width: 40px;
            height: 40px;
            font-size: 20px;
        }

        .dots {
            gap: 10px;
        }

        .dot.active {
            width: 30px;
        }
    }
</style>

<script>
    let slideIndex = 0;
    let autoSlide;

    function showSlide(n) {
        const slides = document.querySelectorAll('.slide');
        const dots = document.querySelectorAll('.dot');
        
        if (n >= slides.length) slideIndex = 0;
        if (n < 0) slideIndex = slides.length - 1;
        
        slides.forEach(slide => slide.classList.remove('active'));
        dots.forEach(dot => dot.classList.remove('active'));
        
        slides[slideIndex].classList.add('active');
        dots[slideIndex].classList.add('active');
    }

    function changeSlide(n) {
        slideIndex += n;
        showSlide(slideIndex);
        resetAutoSlide();
    }

    function currentSlide(n) {
        slideIndex = n;
        showSlide(slideIndex);
        resetAutoSlide();
    }

    function autoPlay() {
        slideIndex++;
        showSlide(slideIndex);
    }

    function resetAutoSlide() {
        clearInterval(autoSlide);
        autoSlide = setInterval(autoPlay, 6000);
    }

    // Start auto-play when page loads
    document.addEventListener('DOMContentLoaded', function() {
        showSlide(slideIndex);
        autoSlide = setInterval(autoPlay, 6000);
    });
</script>



